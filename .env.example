# ── API Keys ───────────────────────────────────────────────────────
#
#   Your Gemini API key. All agents and services use this single key.
#   Get one at https://aistudio.google.com/apikey

GEMINI_API_KEY="your_api_key_here"

# ── Agent Model ────────────────────────────────────────────────────
#
#   Cyrano is the wordsmith. He benefits from a stronger model.
#   See Architecture/LLM-Strategy.md for model rationale.

CYRANO_MODEL="gemini-2.5-flash"

# ── Infrastructure ─────────────────────────────────────────────────
#
#   CONTEXT_MANAGER_LLM — Model used by the context service to
#   summarize conversation history during compaction. Should be
#   fast and cheap; summarization doesn't need creativity.
#   Defaults to CYRANO_MODEL if not set.
#
#   CONTEXT_MAX — Maximum context window in tokens. The context
#   service triggers compaction at 90% of this value.
#   Defaults to 131072 (128K) if not set.

CONTEXT_MANAGER_LLM="gemini-3.1-flash-lite-preview"
CONTEXT_MAX=131072

# ── Infrastructure Trust Plane ────────────────────────────────────
#
#   CYRANO_AGENT_ID — Cyrano's identifier in the Agent Registry.
#
#   CYRANO_TRUST_BADGE — Shared secret between Cyrano and the
#   Agent Registry. Generated by scripts/mock_ca.py and
#   written to certs/cyrano_trust_badge.txt. Copy the value here.
#
#   REGISTRY_URL — Where the Agent Registry listens.
#
#   CA_CERT_PATH — Path to the Mock CA root certificate. All TLS
#   connections verify server certs against this CA.
#
#   PAIRING_VERIFY_KEY — Path to the HMAC key that Chris uses to
#   verify pairing assertions signed by the Registry.

CYRANO_AGENT_ID="cyrano-001"
CYRANO_TRUST_BADGE="paste_value_from_certs/cyrano_trust_badge.txt"
REGISTRY_URL="https://localhost:8003"
CA_CERT_PATH="certs/ca.crt"
PAIRING_VERIFY_KEY="certs/registry_signing.key"

#   CHRIS_CREDENTIAL — Shared secret between Chris and the Agent
#   Registry. Chris presents it with every request to the AR.
#   Generated by scripts/mock_ca.py and written to
#   certs/chris_credential.txt. Copy the value here.
#
#   This is NOT a Trust Badge. Trust Badges are user-facing earned
#   trust from external teams. Chris's credential is infrastructure
#   authentication that users never see.

CHRIS_CREDENTIAL="paste_value_from_certs/chris_credential.txt"
